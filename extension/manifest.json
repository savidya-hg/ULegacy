{
  "manifest_version": 3,
  "name": "ULegacy",
  "version": "1.0.0",
  "description": "Post Mortem Data Management - Dead Man's Switch",
  "permissions": [
    "storage",
    "idle",
    "alarms",
    "webNavigation",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.google.com/*",
    "https://*.instagram.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.google.com/*",
        "https://*.instagram.com/*"
      ],
      "js": [
        "content/privacy-shield.js",
        "content/navigation-guard.js",
        "content/guided-logic.js"
      ],
      "run_at": "document_start"
    }
  ]
}